# Application
APP_NAME=InsuranceAPI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/insurance_db

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
